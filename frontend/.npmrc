# npm v7+ enforces peer dependency resolution by default; this project has a
# handful of peer-dep conflicts in the eslint plugin tree (eslint-config-it4c
# pulls in neostandard / eslint-plugin-react / etc. with overlapping ranges).
# Honouring strict resolution would break dependabot's lockfile updates and
# `npm ci` in CI. Tolerate the overrides — same behaviour we already accept
# at install time via the `npm warn ERESOLVE overriding peer dependency`
# messages.
legacy-peer-deps=true
