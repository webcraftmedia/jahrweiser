# `force=true` bypasses npm's strict peer-dependency *range* checks (turns
# the ERESOLVE refusals into warnings) WITHOUT disabling the auto-install of
# peer dependencies (unlike `legacy-peer-deps=true`).
#
# Why we need this:
# - eslint 10 is fresh; several plugins in our tree (eslint-plugin-import-x,
#   eslint-plugin-react, neostandard, eslint-plugin-promise) still declare
#   peer ranges for eslint 8/9.
# - They work fine with eslint 10 at runtime, but their peer declarations
#   would otherwise block dependabot's `npm install` and our CI's `npm ci`.
#
# Trade-off: `force=true` also relaxes other safety checks (e.g., allows
# republishing the same version). We don't publish from CI, so the install
# behaviour is what matters.
force=true
