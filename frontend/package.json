{
  "name": "frontend",
  "version": "1.9.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "cross-env TZ=UTC nuxt build",
    "dev": "cross-env TZ=UTC nuxt dev",
    "generate": "cross-env TZ=UTC nuxt generate",
    "preview": "cross-env TZ=UTC nuxt preview",
    "postinstall": "cross-env TZ=UTC nuxt prepare",
    "prod:start": "nuxt start",
    "test:lint": "npm run test:lint:eslint && npm run test:lint:locales && npm run test:lint:typecheck",
    "test:lint:typecheck": "vue-tsc --noEmit",
    "test:lint:eslint": "eslint --max-warnings 0 .",
    "test:lint:locales": "scripts/locales/locales.sh ./locales",
    "test:size": "size-limit",
    "test:e2e": "playwright test",
    "test:e2e:full-stack": "playwright test --config=playwright.full-stack.config.ts",
    "test:unit": "vitest run --coverage",
    "test:unit:dev": "vitest",
    "cli:admin:grant": "npx tsx cli/admin-grant.ts",
    "cli:admin:revoke": "npx tsx cli/admin-revoke.ts",
    "cli:admin:tags:grant": "npx tsx cli/admin-tags-grant.ts",
    "cli:admin:tags:revoke": "npx tsx cli/admin-tags-revoke.ts",
    "cli:newsletter:subscribe": "npx tsx cli/newsletter-subscribe.ts",
    "cli:newsletter:unsubscribe": "npx tsx cli/newsletter-unsubscribe.ts",
    "cli:ics:import": "npx tsx cli/ics-import.ts",
    "cli:sync:run": "npx tsx cli/sync-run.ts",
    "cli:seed:reset": "npx tsx cli/seed-reset.ts",
    "cli:seed:demo": "npx tsx cli/seed-demo.ts",
    "cli:baikal:bootstrap": "npx tsx cli/baikal-bootstrap.ts",
    "cli:dav:purge-auth-xprops": "npx tsx cli/dav-purge-auth-xprops.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx scripts/db-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@schedule-x/calendar": "4.6.0",
    "@schedule-x/calendar-controls": "4.6.0",
    "@schedule-x/events-service": "4.6.0",
    "@schedule-x/theme-default": "4.6.0",
    "@schedule-x/vue": "4.1.0",
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.2",
    "email-templates": "^13.0.1",
    "ical.js": "^2.2.1",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.10",
    "nuxt": "^4.4.6",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-svgo": "^5.3.0",
    "pug": "^3.0.4",
    "temporal-polyfill": "0.3.0",
    "tsdav": "^2.1.8",
    "tsx": "^4.22.4",
    "vue": "^3.5.30",
    "vue-router": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@testing-library/vue": "^8.1.0",
    "@types/email-templates": "^10.0.4",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-config-it4c": "^0.12.0",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.3.3"
  }
}
