# All values below are OPTIONAL for local development — the defaults in
# nuxt.config.ts already match the docker-compose stack. Set them when running
# against staging/production.
NUXT_SESSION_PASSWORD=12345678901234567890123456789012
# DAV (defaults: http://localhost:8088, admin/admin — /dav.php path appended internally)
DAV_URL=http://localhost:8088
DAV_USERNAME=admin
DAV_PASSWORD=admin
# Database (defaults: localhost:3306, jahrweiser/jahrweiser/jahrweiser)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jahrweiser
DB_USER=jahrweiser
DB_PASSWORD=jahrweiser
# Bearer secret for the daily sync endpoint (default: dev-sync-secret)
SYNC_SECRET=dev-sync-secret
# SMTP (defaults: localhost:1025 — matches docker-compose maildev port mapping)
SMTP_HOST=localhost
SMTP_PORT=1025
# Domain
CLIENT_URI=http://localhost:3000